{
  "name": "transcriber",
  "version": "1.0.0",
  "description": "An Amazing Capacitor App",
  "author": {
    "name": "Jonathan",
    "email": ""
  },
  "repository": {
    "type": "git",
    "url": "https://google.com"
  },
  "license": "MIT",
  "main": "build/src/index.js",
  "scripts": {
    "build": "tsc && electron-rebuild",
    "electron:start-live": "node ./live-runner.js",
    "electron:start": "pnpm run build && electron --inspect=5858 ./",
    "electron:pack": "pnpm run build && electron-builder build --dir -c ./electron-builder.config.json",
    "electron:make": "pnpm run build && electron-builder build -c ./electron-builder.config.json -p always"
  },
  "dependencies": {
    "@capacitor-community/electron": "^5.0.0",
    "chokidar": "~3.5.3",
    "electron-is-dev": "~2.0.0",
    "electron-serve": "~1.1.0",
    "electron-unhandled": "~4.0.1",
    "electron-updater": "^5.3.0",
    "electron-window-state": "^5.0.3"
  },
  "devDependencies": {
    "electron": "^26.2.2",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.0.4"
  },
  "keywords": [
    "capacitor",
    "electron"
  ],
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "lzma-native"]
  }
}
